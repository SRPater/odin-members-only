<%- include('partials/header') %>
<%- include('partials/nav') %>

<main>
  <h1><%= title %></h1>

  <% if (locals.currentUser) { %>
    <a href="/messages/new" class="btn">Post New Message</a>
  <% } %>

  <section class="message-list">
    <% if (messages && messages.length > 0) { %>
      <% messages.forEach(msg => { %>
        <div class="message-card">
          <h2><%= msg.title %></h2>
          <p><%= msg.text %></p>

          <hr>

          <div class="meta">
            <div class="meta-info">
              <% if (locals.currentUser && currentUser.is_member) { %>
                <p>
                  By: <strong><%= msg.first_name %> <%= msg.last_name %></strong>
                </p>
                <p>Posted: <%= msg.timestamp.toLocaleString('nl-NL') %></p>
              <% } else { %>
                <p>
                  <em>
                    Author hidden. Become a member to see who posted this!
                  </em>
                </p>
              <% } %>
            </div>

            <% if (locals.currentUser && currentUser.is_admin) { %>
              <form action="/messages/<%= msg.id %>/delete" method="POST">
                <button type="submit" class="delete-btn">Delete Message</button>
              </form>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p>The clubhouse is quiet... No messages yet.</p>
    <% } %>
  </section>
</main>

<%- include('partials/footer') %>